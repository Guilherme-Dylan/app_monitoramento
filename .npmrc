# Configurações do pnpm

# Usar lockfile congelado por padrão (mais seguro para CI/CD)
frozen-lockfile=true

# Permitir scripts de build
ignore-scripts=false

# Usar versão exata de dependências
save-exact=false

# Diretório de node_modules
node-linker=hoisted

# Habilitar verificação de integridade
verify-store-integrity=true
